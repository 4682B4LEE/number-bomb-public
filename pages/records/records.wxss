page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', sans-serif;
}

/* --- 加载动画 --- */
.loading-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F5F5F7;
}
.loading-icon-box { position: relative; width: 160rpx; height: 160rpx; margin-bottom: 40rpx; }
.icon-bounce {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  animation: bounce 1s infinite; z-index: 10;
}
.icon-inner {
  background: #ffffff; padding: 24rpx; border-radius: 40rpx; font-size: 64rpx; line-height: 1;
  box-shadow: 0 16rpx 60rpx rgba(0,0,0,0.08); color: #E53935;
}
.shadow-pulse {
  position: absolute; bottom: -10rpx; left: 50%; transform: translateX(-50%);
  width: 60rpx; height: 16rpx; background: #e2e8f0; border-radius: 50%;
  animation: pulse 1s infinite;
}
.loading-text { font-size: 36rpx; font-weight: bold; color: #4A5568; letter-spacing: 4rpx; animation: pulseText 1.5s infinite; }
.loading-sub { font-size: 26rpx; color: #A0AEC0; margin-top: 16rpx; }

@keyframes bounce { 0%, 100% { transform: translateY(-25%); animation-timing-function: cubic-bezier(0.8,0,1,1); } 50% { transform: translateY(0); animation-timing-function: cubic-bezier(0,0,0.2,1); } }
@keyframes pulse { 0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.5; } 50% { transform: translateX(-50%) scale(1.5); opacity: 0.2; } }
@keyframes pulseText { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  width: 100%;
  position: relative;
}

/* 顶部背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  background: linear-gradient(to bottom, #E8E8ED, transparent);
  z-index: -1;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx 40rpx; /* 适配状态栏高度 */
  position: relative;
}

.back-btn {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  z-index: 10;
}

.back-btn .back-text {
  display: none;
}

.back-arrow {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.arrow-line {
  position: absolute;
  width: 20rpx;
  height: 4rpx;
  background: #6b7280;
  top: 50%;
  left: 6rpx;
  transform: translateY(-50%);
  border-radius: 2rpx;
}

.arrow-head {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid #6b7280;
  border-bottom: 4rpx solid #6b7280;
  top: 50%;
  left: 4rpx;
  transform: translateY(-50%) rotate(45deg);
}

.back-text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 600;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: #2C313A;
}

/* 主体内容 */
.content {
  flex: 1;
  padding: 0 40rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 标签切换 */
.tabs {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  padding: 12rpx;
  border-radius: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.03);
  margin-bottom: 48rpx;
  width: 100%;
}

.tab-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 28rpx;
  color: #999999;
  transition: all 0.3s ease;
}

.tab-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.active-number {
  background-color: #E53935;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(229,57,53,0.3);
}

.active-color {
  background-color: #FACC15;
  color: #854D0E;
  box-shadow: 0 8rpx 24rpx rgba(250,204,21,0.4);
}

.active-online {
  background-color: #3B82F6;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.4);
}

/* 数据总览卡片 */
.stats-card {
  background: #ffffff;
  border-radius: 48rpx;
  padding: 48rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
  box-shadow: 0 16rpx 60rpx rgba(0,0,0,0.04);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.align-right {
  align-items: flex-end;
}

.stat-label {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.stat-value-box {
  display: flex;
  align-items: baseline;
}

.stat-num {
  font-size: 72rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.stat-unit {
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 8rpx;
}

.blue { color: #00A3DA; }
.black { color: #2C313A; }

.divider {
  width: 2rpx;
  height: 80rpx;
  background-color: #F0F0F0;
}

/* 历史对局标题 */
.history-title-box {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 刷新提示 */
.refresh-hint {
  text-align: center;
  margin-bottom: 16rpx;
}

.refresh-hint .hint-text {
  font-size: 22rpx;
  color: #999;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
}

.history-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C313A;
}

.history-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 16rpx;
}

/* 历史对局列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-card {
  background: #ffffff;
  border-radius: 36rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.02);
  position: relative;
}

/* 收藏卡片样式 */
.favorite-card {
  border: 2rpx solid #FACC15;
  background: linear-gradient(135deg, #FFFBEB 0%, #ffffff 100%);
}



.history-card:active {
  transform: scale(0.98);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-top-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tag-type {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.tag-icon { margin-right: 8rpx; font-size: 20rpx; }

.tag-red { background: #FEF2F2; color: #DC2626; }
.tag-yellow { background: #FEFCE8; color: #A16207; }
.tag-blue { background: #EFF6FF; color: #1D4ED8; }
.tag-purple { background: #F3E8FF; color: #7C3AED; }
.tag-quick-draw { background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); color: #B45309; border: 1rpx solid #F59E0B; }

.card-time {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.tag-status {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-win { background: #DCFCE7; color: #16A34A; }
.status-lose { background: #FEE2E2; color: #EF4444; }
.status-draw { background: #E5E7EB; color: #6B7280; }
.status-timeout { background: #FEF3C7; color: #F59E0B; }

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4rpx;
}

.players {
  display: flex;
  align-items: center;
}

.icon-user {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.player-name-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.player-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #4A5568;
}

.result-badge {
  font-size: 20rpx;
  font-weight: bold;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.result-badge.badge-win {
  background: #DCFCE7;
  color: #16A34A;
}

.result-badge.badge-lose {
  background: #FEE2E2;
  color: #EF4444;
}

.result-badge.badge-draw {
  background: #F3F4F6;
  color: #6B7280;
}

.vs {
  font-size: 24rpx;
  color: #CBD5E1;
  font-weight: bold;
  margin: 0 16rpx;
}

.rounds-tag {
  font-size: 24rpx;
  font-weight: bold;
  color: #94A3B8;
  background: #F8FAFC;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 底部提示 */
.bottom-hint {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 60rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  background: #ffffff;
  border-radius: 48rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.02);
  margin-top: 20rpx;
}

.empty-icon-box {
  width: 140rpx;
  height: 140rpx;
  background: #F8FAFC;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon { font-size: 64rpx; }
.empty-title { font-size: 32rpx; font-weight: bold; color: #2C313A; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #94A3B8; }

/* 操作菜单弹窗 */
.action-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.action-menu {
  width: 100%;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.action-menu-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C313A;
  text-align: center;
  margin-bottom: 40rpx;
}

.action-menu-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  transition: all 0.2s;
}

.action-menu-item:active {
  transform: scale(0.98);
}

.action-menu-item.favorite {
  background: #FFFBEB;
}

.action-menu-item.cancel-favorite {
  background: #F3F4F6;
}

.action-menu-item.delete {
  background: #FEF2F2;
}

.action-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
}

.action-menu-item.favorite .action-text {
  color: #A16207;
}

.action-menu-item.cancel-favorite .action-text {
  color: #4B5563;
}

.action-menu-item.delete .action-text {
  color: #DC2626;
}

.action-menu-cancel {
  text-align: center;
  padding: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #6B7280;
  background: #F3F4F6;
  border-radius: 24rpx;
}

.action-menu-cancel:active {
  background: #E5E7EB;
}

/* 删除确认弹窗 */
.confirm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1001;
}

.confirm-dialog {
  width: 560rpx;
  background: #ffffff;
  border-radius: 36rpx;
  padding: 48rpx;
  text-align: center;
}

.confirm-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2C313A;
  margin-bottom: 24rpx;
}

.confirm-content {
  font-size: 28rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.confirm-buttons {
  display: flex;
  gap: 24rpx;
}

.confirm-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.confirm-btn.cancel {
  background: #F3F4F6;
  color: #6B7280;
}

.confirm-btn.confirm {
  background: #DC2626;
  color: #ffffff;
}

.confirm-btn:active {
  opacity: 0.8;
}

/* 数据迁移弹窗样式 */
.migration-dialog {
  width: 600rpx;
}

.migration-dialog .confirm-content {
  text-align: left;
  line-height: 1.8;
}

.confirm-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}
