/* 猜颜色游戏进行页样式 - Royal Design System */

/* 页面容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 玩家1背景 - 红色渐变 */
.bg-p1 {
  background:
    radial-gradient(circle at 10% 20%, rgba(255, 60, 40, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(255, 150, 150, 0.1) 0%, transparent 40%),
    #f8fafc;
}

/* 玩家2背景 - 蓝色渐变 */
.bg-p2 {
  background:
    radial-gradient(circle at 90% 20%, rgba(0, 195, 227, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 10% 80%, rgba(100, 230, 255, 0.1) 0%, transparent 40%),
    #f8fafc;
}

/* 顶部信息栏 - Glassmorphism */
.header-bar {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 20;
}

.player-badge {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.badge-p1 {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 60, 40, 0.3);
}

.badge-p2 {
  background: linear-gradient(135deg, #4dd0e1 0%, #00c3e3 100%);
  box-shadow: 0 4rpx 16rpx rgba(0, 195, 227, 0.3);
}

.turn-text {
  font-size: 28rpx;
  color: #4b5563;
  margin-left: 16rpx;
  font-weight: 600;
}

/* 【测试用】正确答案显示区域 */
.secret-section {
  width: 90%;
  max-width: 680rpx;
  background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
  border-radius: 24rpx;
  padding: 20rpx 32rpx;
  margin: 20rpx auto;
  border: 2rpx dashed #ff9800;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.secret-label {
  font-size: 24rpx;
  color: #e65100;
  font-weight: 700;
}

.secret-colors {
  display: flex;
  gap: 16rpx;
}

.secret-color {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 历史记录区域 */
.history-section {
  flex: 1;
  width: 90%;
  max-width: 680rpx;
  margin: 0 auto 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12px);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.history-title {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 700;
  margin-bottom: 20rpx;
  display: block;
  text-align: center;
  letter-spacing: 2rpx;
}

.history-list {
  flex: 1;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(8px);
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-left: 6rpx solid transparent;
  justify-content: space-between;
}

.history-item.item-p1 {
  border-left-color: #ff3c28;
}

.history-item.item-p2 {
  border-left-color: #00c3e3;
}

.guess-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 72rpx;
  margin-right: 16rpx;
}

.guess-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  color: white;
  margin-bottom: 8rpx;
}

.item-p1 .guess-number {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
  box-shadow: 0 2rpx 8rpx rgba(255, 60, 40, 0.3);
}

.item-p2 .guess-number {
  background: linear-gradient(135deg, #4dd0e1 0%, #00c3e3 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 195, 227, 0.3);
}

.player-tag {
  font-size: 18rpx;
  font-weight: 900;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag-p1 {
  background: rgba(255, 60, 40, 0.15);
  color: #ff3c28;
}

.tag-p2 {
  background: rgba(0, 195, 227, 0.15);
  color: #00c3e3;
}

.guess-colors {
  display: flex;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-start;
  width: 232rpx;
  flex-shrink: 0;
}

/* 颜色 Pin - Royal Design */
.history-color {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
  position: relative;
}

/* 颜色定义 - Royal Design System */
.red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.gray {
  background: radial-gradient(circle at 30% 30%, #cbd5e1, #64748b, #334155);
}

/* 提示标记区域 */
.guess-hints {
  display: flex;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(243, 244, 246, 0.8);
  border-radius: 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.hint-red {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ff3c28;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(255, 60, 40, 0.3);
}

.hint-white {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: white;
  border: 2rpx solid #d1d5db;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.empty-history {
  text-align: center;
  padding: 60rpx;
  color: #9ca3af;
  font-size: 28rpx;
  font-weight: 600;
}

/* 底部控制区域 - Floating Card */
.control-section {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16px);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.08);
  padding: 40rpx 32rpx 48rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 30;
}

/* 回合徽章 */
.turn-badge {
  position: absolute;
  top: -32rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  color: white;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15), 0 0 0 4rpx white;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.turn-badge.p1 {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
}

.turn-badge.p2 {
  background: linear-gradient(135deg, #4dd0e1 0%, #00c3e3 100%);
}

/* 输入区域 */
.input-section {
  margin-bottom: 32rpx;
  margin-top: 16rpx;
}

.colors-display {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.color-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: rgba(243, 244, 246, 0.8);
  border: 2rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.color-box-empty {
  background: rgba(243, 244, 246, 0.8);
}

.color-box-empty::after {
  content: '+';
  font-size: 48rpx;
  color: #d1d5db;
  font-weight: 300;
}

.color-box-editing {
  border-color: #ff3c28;
  transform: scale(1.05);
  box-shadow: 0 0 0 4rpx rgba(255, 60, 40, 0.2);
}

.color-fill {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.edit-indicator {
  position: absolute;
  bottom: -8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff3c28;
  border-radius: 50%;
  box-shadow: 0 2rpx 4rpx rgba(255, 60, 40, 0.3);
}

/* 颜色选择键盘 */
.color-keypad {
  margin-bottom: 24rpx;
}

.color-keypad-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.color-key {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 0 #e5e7eb,
    0 6rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.15s ease;
}

.color-key:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #e5e7eb, 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.color-key-fill {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

/* 操作按钮区域 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.action-key {
  width: 100rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #6b7280;
  background: rgba(243, 244, 246, 0.8);
  box-shadow: 0 6rpx 0 #d1d5db;
  transition: all 0.15s ease;
}

.action-key:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #d1d5db;
}

/* 提交按钮 - 3D Effect */
.confirm-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  position: relative;
  overflow: hidden;
}

.confirm-btn::after {
  border: none;
}

.btn-p1 {
  background: linear-gradient(180deg, #ff6b6b 0%, #ff3c28 100%);
  box-shadow: 0 6rpx 0 #cc2a1a;
}

.btn-p1:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #cc2a1a;
}

.btn-p2 {
  background: linear-gradient(180deg, #4dd0e1 0%, #00c3e3 100%);
  box-shadow: 0 6rpx 0 #009cb8;
}

.btn-p2:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #009cb8;
}

.btn-disabled {
  background: #d1d5db;
  box-shadow: 0 6rpx 0 #9ca3af;
  color: rgba(255, 255, 255, 0.7);
}

.btn-disabled:active {
  transform: none;
  box-shadow: 0 6rpx 0 #9ca3af;
}

/* 提示说明 */
.hint-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx 0 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.red-dot {
  background: #ff3c28;
}

.white-dot {
  background: white;
  border-color: #d1d5db;
}

.legend-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}
