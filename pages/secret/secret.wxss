/* 密码设置页样式 */
.bg-p1 {
  background-color: #FFF1F2;
}

.bg-p2 {
  background-color: #F0F9FF;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.player-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #6B7280;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #9CA3AF;
}

.digits-display {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.digit-box {
  width: 112rpx;
  height: 128rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 900;
}

.digit-box-empty {
  background: white;
  border: 4rpx solid #F3F4F6;
  color: #D1D5DB;
}

.digit-box-filled {
  background: white;
  border: 4rpx solid #E5E7EB;
  color: #374151;
  box-shadow: 0 8rpx 0 #E5E7EB;
  position: relative;
}

/* 编辑状态样式 */
.digit-box-editing {
  background: #FFF1F2;
  border: 4rpx solid #E60012;
  box-shadow: 0 8rpx 0 #E60012, 0 0 20rpx rgba(230, 0, 18, 0.3);
  animation: editPulse 1s ease infinite;
}

@keyframes editPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 编辑指示器 */
.edit-indicator {
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: #E60012;
  border-radius: 2rpx;
}

.digit-text {
  font-family: 'Varela Round', 'Nunito', sans-serif;
}

.hint-box {
  margin-bottom: 60rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #6B7280;
}

/* 数字键盘 */
.keypad {
  width: 100%;
  max-width: 640rpx;
  padding: 0 32rpx;
}

.keypad-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.key {
  width: 160rpx;
  height: 128rpx;
  background: white;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #374151;
  box-shadow: 0 8rpx 0 #E5E7EB;
  transition: all 0.1s;
}

.key:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #E5E7EB;
}

.key-clear {
  background: #FFE4E6;
  color: #F43F5E;
  box-shadow: 0 8rpx 0 #FECDD3;
}

.key-clear:active {
  box-shadow: 0 0 0 #FECDD3;
}

.key-delete {
  background: #F3F4F6;
  color: #6B7280;
  box-shadow: 0 8rpx 0 #D1D5DB;
}

.key-delete:active {
  box-shadow: 0 0 0 #D1D5DB;
}

.delete-icon {
  font-size: 40rpx;
}

.confirm-btn {
  width: 100%;
  height: 128rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  border: none;
  font-size: 40rpx;
  font-weight: 900;
  color: white;
  box-shadow: 0 8rpx 0 rgba(0,0,0,0.2);
  transition: all 0.1s;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 rgba(0,0,0,0.2);
}

.btn-p1 {
  background-color: #E60012;
  box-shadow: 0 8rpx 0 #99000C;
}

.btn-p1:active {
  box-shadow: 0 0 0 #99000C;
}

.btn-p2 {
  background-color: #00B3E6;
  box-shadow: 0 8rpx 0 #0088B3;
}

.btn-p2:active {
  box-shadow: 0 0 0 #0088B3;
}

.btn-disabled {
  background-color: #E5E7EB;
  color: #9CA3AF;
  box-shadow: 0 8rpx 0 #D1D5DB;
}
