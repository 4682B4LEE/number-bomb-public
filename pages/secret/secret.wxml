<!-- 密码设置页 -->
<view class="container {{isP1 ? 'bg-p1' : 'bg-p2'}}">
  <!-- 标题 -->
  <view class="header">
    <text class="player-label">{{playerName}}</text>
    <text class="page-title">设定你的密码</text>
    <text class="page-subtitle">输入 {{digitCount}} 位数字</text>
  </view>

  <!-- 数字显示区 -->
  <view class="digits-display">
    <view 
      wx:for="{{displayDigits}}" 
      wx:key="index"
      class="digit-box {{item ? 'digit-box-filled' : 'digit-box-empty'}} {{editIndex === index ? 'digit-box-editing' : ''}}"
      bindtap="onDigitTap"
      data-index="{{index}}"
    >
      <text class="digit-text">{{item || ''}}</text>
      <view wx:if="{{editIndex === index}}" class="edit-indicator"></view>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="hint-box">
    <text class="hint-text">{{hintText}}</text>
  </view>

  <!-- 数字键盘 -->
  <view class="keypad">
    <view class="keypad-row">
      <view class="key" bindtap="onKeyPress" data-key="1">1</view>
      <view class="key" bindtap="onKeyPress" data-key="2">2</view>
      <view class="key" bindtap="onKeyPress" data-key="3">3</view>
    </view>
    <view class="keypad-row">
      <view class="key" bindtap="onKeyPress" data-key="4">4</view>
      <view class="key" bindtap="onKeyPress" data-key="5">5</view>
      <view class="key" bindtap="onKeyPress" data-key="6">6</view>
    </view>
    <view class="keypad-row">
      <view class="key" bindtap="onKeyPress" data-key="7">7</view>
      <view class="key" bindtap="onKeyPress" data-key="8">8</view>
      <view class="key" bindtap="onKeyPress" data-key="9">9</view>
    </view>
    <view class="keypad-row">
      <view class="key key-clear" bindtap="onClear">C</view>
      <view class="key" bindtap="onKeyPress" data-key="0">0</view>
      <view class="key key-delete" bindtap="onDelete">
        <text class="delete-icon">←</text>
      </view>
    </view>
    <!-- 确认按钮 -->
    <button 
      class="confirm-btn {{canConfirm ? (isP1 ? 'btn-p1' : 'btn-p2') : 'btn-disabled'}}" 
      bindtap="onConfirm"
      disabled="{{!canConfirm}}"
    >
      <text>确定</text>
    </button>
  </view>
</view>
