/* 猜颜色游戏模式选择页样式 - Royal Design System */

/* 页面容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background:
    radial-gradient(circle at 20% 30%, rgba(255, 60, 40, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(0, 195, 227, 0.1) 0%, transparent 50%),
    #f8fafc;
}

/* 标题区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

/* Logo 样式 - Glassmorphism */
.logo-box {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12px);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  margin-bottom: 24rpx;
}

.color-logo {
  background: linear-gradient(135deg, rgba(252, 211, 77, 0.9) 0%, rgba(245, 158, 11, 0.9) 100%) !important;
}

.color-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 2x2 彩色棋子网格 - 标题区域 */
.color-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(4rpx);
  border-radius: 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.1), 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.color-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  box-shadow:
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    0 1rpx 2rpx rgba(0, 0, 0, 0.15);
}

.dot-red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.dot-green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.dot-blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.dot-purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.dot-yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #1f2937;
  margin-top: 24rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 12rpx;
  font-weight: 600;
}

/* 卡片样式 - Glassmorphism */
.card {
  width: 100%;
  max-width: 600rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 48rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(16px);
  border-radius: 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.card-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #4b5563;
  font-weight: 700;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

/* 模式选择网格 */
.mode-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.mode-btn {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(243, 244, 246, 0.8);
  border-radius: 28rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
  box-shadow: 0 8rpx 0 #d1d5db;
}

.mode-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #d1d5db;
}

.mode-btn.active {
  background: rgba(255, 255, 255, 0.95);
  border-color: #00c3e3;
  box-shadow: 0 8rpx 0 #009cb8;
}

.mode-btn.active:active {
  box-shadow: 0 0 0 #009cb8;
}

.mode-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

/* 模式选择 2x2 彩色棋子网格 */
.mode-color-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  padding: 8rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

.mode-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  box-shadow:
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.mode-dot.dot-red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.mode-dot.dot-green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.mode-dot.dot-blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.mode-dot.dot-purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.mode-dot.dot-yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.mode-info {
  flex: 1;
}

.mode-label {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
}

/* 游戏模式选择区域 */
.play-mode-section {
  margin-top: 48rpx;
  padding-top: 48rpx;
  border-top: 2rpx solid #E5E7EB;
}

.play-mode-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #4B5563;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.play-mode-buttons {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.play-mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  border-radius: 24rpx;
  background: #F3F4F6;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
  box-shadow: 0 8rpx 0 #D1D5DB;
}

.play-mode-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #D1D5DB;
}

.play-mode-btn.active {
  background: white;
  border-color: rgba(0, 195, 227, 0.3);
  box-shadow: 0 8rpx 0 rgba(0, 195, 227, 0.2);
}

.play-mode-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 单人模式图标 */
.icon-single {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.single-person {
  width: 32rpx;
  height: 40rpx;
  background: #6B7280;
  border-radius: 16rpx 16rpx 10rpx 10rpx;
  position: relative;
}

.single-person::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 14rpx;
  background: white;
  border-radius: 50%;
}

.play-mode-btn.active .single-person {
  background: #00c3e3;
}

/* 本地双人图标 */
.icon-local {
  width: 48rpx;
  height: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.local-person {
  width: 20rpx;
  height: 32rpx;
  background: #6B7280;
  border-radius: 10rpx 10rpx 6rpx 6rpx;
  position: absolute;
}

.local-person::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 10rpx;
  background: white;
  border-radius: 50%;
}

.person-left {
  left: 4rpx;
}

.person-right {
  right: 4rpx;
}

.play-mode-btn.active .local-person {
  background: #00c3e3;
}

.play-mode-text {
  font-size: 26rpx;
  color: #6B7280;
  font-weight: 700;
}

.play-mode-btn.active .play-mode-text {
  color: #00c3e3;
}

/* 开始按钮 - 3D Effect */
.start-btn {
  width: 100%;
  max-width: 600rpx;
  height: 100rpx;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  background: linear-gradient(180deg, #4dd0e1 0%, #00c3e3 100%);
  box-shadow: 0 8rpx 0 #009cb8;
  margin-bottom: 32rpx;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #009cb8;
}

/* 返回按钮 - 紧凑型 */
.back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.back-btn .back-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
  margin-left: 8rpx;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.arrow-line {
  position: absolute;
  width: 16rpx;
  height: 3rpx;
  background: #6b7280;
  top: 50%;
  left: 4rpx;
  transform: translateY(-50%);
  border-radius: 2rpx;
}

.arrow-head {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-left: 3rpx solid #6b7280;
  border-bottom: 3rpx solid #6b7280;
  top: 50%;
  left: 2rpx;
  transform: translateY(-50%) rotate(45deg);
}

.back-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}
