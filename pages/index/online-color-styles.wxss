/* 联机猜颜色样式 - 基于本地双人猜颜色样式复用改造 */
/* 使用 online-color- 前缀避免与猜数字样式冲突 */

/* 容器 */
.online-color-game-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 房主背景 - 红色渐变 */
.online-color-game-container.bg-host {
  background:
    radial-gradient(circle at 10% 20%, rgba(255, 60, 40, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 90% 80%, rgba(255, 150, 150, 0.1) 0%, transparent 40%),
    #f8fafc;
}

/* 客人背景 - 蓝色渐变 */
.online-color-game-container.bg-guest {
  background:
    radial-gradient(circle at 90% 20%, rgba(0, 195, 227, 0.15) 0%, transparent 40%),
    radial-gradient(circle at 10% 80%, rgba(100, 230, 255, 0.1) 0%, transparent 40%),
    #f8fafc;
}

/* 顶部信息栏 - 新布局：左中右三栏 */
.online-color-header {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.5);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 20;
}

/* 左上角信息 */
.online-color-left-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 120rpx;
}

.online-color-round {
  font-size: 26rpx;
  color: #4b5563;
  font-weight: 700;
}

.online-color-remaining {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* 中间回合按钮（居中） */
.online-color-turn-badge {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #6b7280;
  background: rgba(243, 244, 246, 0.8);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.online-color-turn-badge.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(255, 60, 40, 0.3);
}

/* 右上角房间倒计时 */
.online-color-right-info {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 120rpx;
}

.online-color-room-timer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.online-color-room-timer .timer-label {
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.online-color-room-timer .timer-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #4b5563;
}

.online-color-room-timer.warning {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
}

.online-color-room-timer.warning .timer-label,
.online-color-room-timer.warning .timer-value {
  color: white;
}

/* 对决模式倒计时（保留用于对决模式） */
.online-color-duel-timer {
  padding: 12rpx 24rpx;
  background: #333;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.online-color-duel-timer.warning {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3c28 100%);
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* 历史记录区域 */
.online-color-history-section {
  flex: 1;
  width: 90%;
  max-width: 680rpx;
  margin: 20rpx auto;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12px);
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.online-color-history-list {
  flex: 1;
  overflow-y: auto;
}

/* 历史记录项 - 新布局：序号+1P/2P+颜色+提示 */
.online-color-history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(8px);
  border-radius: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-left: 6rpx solid transparent;
}

.online-color-history-item.tag-host {
  border-left-color: #ff3c28;
}

.online-color-history-item.tag-guest {
  border-left-color: #00c3e3;
}

/* 序号 */
.online-color-seq-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #4b5563;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 玩家标签 */
.online-color-player-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 900;
  min-width: 60rpx;
  text-align: center;
  margin-right: 16rpx;
}

.online-color-player-tag.tag-host {
  background: rgba(255, 60, 40, 0.15);
  color: #ff3c28;
}

.online-color-player-tag.tag-guest {
  background: rgba(0, 195, 227, 0.15);
  color: #00c3e3;
}

/* 颜色显示 - 左对齐 */
.online-color-guess-display {
  display: flex;
  gap: 12rpx;
  flex: 1;
  justify-content: flex-start;
}

.online-color-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

/* 颜色定义 - Royal Design System */
.online-color-dot.red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.online-color-dot.green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.online-color-dot.blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.online-color-dot.yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.online-color-dot.purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.online-color-dot.gray {
  background: radial-gradient(circle at 30% 30%, #cbd5e1, #64748b, #334155);
}

/* 提示点 */
.online-color-hints {
  display: flex;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(243, 244, 246, 0.8);
  border-radius: 16rpx;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.online-color-red-hints,
.online-color-white-hints {
  display: flex;
  gap: 6rpx;
}

.online-color-hint-red {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #ff3c28;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(255, 60, 40, 0.3);
}

.online-color-hint-white {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: white;
  border: 2rpx solid #d1d5db;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 空历史提示 */
.online-color-empty-history {
  text-align: center;
  padding: 60rpx;
  color: #9ca3af;
  font-size: 28rpx;
  font-weight: 600;
}

/* 输入区域 - Floating Card */
.online-color-input-section {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16px);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.08);
  padding: 40rpx 32rpx 48rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 30;
}

/* 颜色显示框 */
.online-color-display-boxes {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.online-color-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: rgba(243, 244, 246, 0.8);
  border: 2rpx dashed #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.3s ease;
}

.online-color-box.empty::after {
  content: '+';
  font-size: 48rpx;
  color: #d1d5db;
  font-weight: 300;
}

.online-color-box.editing {
  border-color: #ff3c28;
  transform: scale(1.05);
  box-shadow: 0 0 0 4rpx rgba(255, 60, 40, 0.2);
}

.online-color-fill {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.online-color-fill.red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.online-color-fill.green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.online-color-fill.blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.online-color-fill.yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.online-color-fill.purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.online-color-fill.gray {
  background: radial-gradient(circle at 30% 30%, #cbd5e1, #64748b, #334155);
}

/* 颜色键盘 */
.online-color-keypad {
  margin-bottom: 24rpx;
}

.online-color-keypad-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.online-color-key {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 0 #e5e7eb,
    0 6rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.15s ease;
}

.online-color-key:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #e5e7eb, 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.online-color-key-fill {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  box-shadow:
    0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.3),
    inset 0 -2rpx 4rpx rgba(0, 0, 0, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.4);
}

.online-color-key-fill.red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.online-color-key-fill.green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.online-color-key-fill.blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.online-color-key-fill.yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.online-color-key-fill.purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.online-color-key-fill.gray {
  background: radial-gradient(circle at 30% 30%, #cbd5e1, #64748b, #334155);
}

/* 操作按钮 */
.online-color-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.online-color-btn-clear {
  width: 100rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #6b7280;
  background: rgba(243, 244, 246, 0.8);
  box-shadow: 0 6rpx 0 #d1d5db;
  transition: all 0.15s ease;
}

.online-color-btn-clear:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #d1d5db;
}

/* 提交按钮 - 3D Effect */
.online-color-btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  background: #d1d5db;
  box-shadow: 0 6rpx 0 #9ca3af;
  transition: all 0.3s ease;
}

.online-color-btn-confirm::after {
  border: none;
}

.online-color-btn-confirm.active {
  background: linear-gradient(180deg, #ff6b6b 0%, #ff3c28 100%);
  box-shadow: 0 6rpx 0 #cc2a1a;
  color: white;
}

.online-color-btn-confirm.active:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #cc2a1a;
}

/* 提示说明 */
.online-color-hint-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 20rpx 0 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.online-color-legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.online-color-legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.online-color-legend-dot.red-dot {
  background: #ff3c28;
}

.online-color-legend-dot.white-dot {
  background: white;
  border-color: #d1d5db;
}

.online-color-legend-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

/* 等待中 */
.online-color-waiting {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(16px);
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.08);
  border-top: 1rpx solid rgba(255, 255, 255, 0.6);
}

.online-color-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: #ff3c28;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.online-color-waiting text {
  font-size: 28rpx;
  color: #6b7280;
  font-weight: 600;
}
