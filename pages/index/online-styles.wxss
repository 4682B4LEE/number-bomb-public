/* ========== 结算页面 - 复用 victory.wxss 样式 ========== */
.online-result-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  padding-top: 120rpx;
  position: relative;
  min-height: 100vh;
  overflow-y: auto;
}

.online-result-container.bg-pattern {
  background: linear-gradient(180deg, #F9FAFB 0%, #F3F4F6 100%);
}

/* 彩带动画 */
.online-result-container .confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 100;
}

.online-result-container .confetti {
  position: absolute;
  top: -20rpx;
  width: 20rpx;
  height: 20rpx;
  opacity: 0.8;
  animation: fall linear infinite;
}

.online-result-container .confetti-red {
  background: #ef4444;
  border-radius: 4rpx;
}

.online-result-container .confetti-blue {
  background: #3b82f6;
  border-radius: 50%;
}

.online-result-container .confetti-gold {
  background: #facc15;
  border-radius: 2rpx;
  transform: rotate(45deg);
}

@keyframes fall {
  0% {
    transform: translateY(-20rpx) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(110vh) rotate(720deg);
    opacity: 0;
  }
}

/* 任天堂风格卡片 */
.online-result-container .nintendo-card {
  background: white;
  border-radius: 48rpx;
  border: 8rpx solid white;
  box-shadow: 0 16rpx 0 0 rgba(0,0,0,0.08);
  width: 100%;
  max-width: 640rpx;
}

/* 胜利宣告卡片 */
.online-result-container .victory-card {
  padding: 120rpx 48rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  margin-bottom: 40rpx;
  z-index: 10;
}

/* 浮动胜利图标 */
.online-result-container .victory-icon-wrapper {
  position: absolute;
  top: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
}

.online-result-container .victory-icon-bg {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  border: 8rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.online-result-container .icon-p1 {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.online-result-container .icon-p2 {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

/* 平局图标背景 - 洗碗图标不需要背景色 */
.online-result-container .icon-wash-bg {
  background: transparent;
  border: 4rpx solid #E5E7EB;
}

/* 失败图标背景 */
.online-result-container .icon-loser {
  background: linear-gradient(135deg, #9CA3AF 0%, #6B7280 100%);
}

/* 星星图标 */
.online-result-container .icon-star {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.online-result-container .star-shape {
  width: 100%;
  height: 100%;
  background: white;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

/* 皇冠图标 */
.online-result-container .icon-crown {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.online-result-container .crown-shape {
  width: 100%;
  height: 60%;
  background: white;
  clip-path: polygon(20% 100%, 0% 40%, 30% 60%, 50% 20%, 70% 60%, 100% 40%, 80% 100%);
  position: absolute;
  bottom: 20%;
}

/* 洗碗图标 */
.online-result-container .icon-wash {
  font-size: 56rpx;
  line-height: 1;
}

/* 卡片内容 */
.online-result-container .victory-content {
