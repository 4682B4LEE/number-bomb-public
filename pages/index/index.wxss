}

.btn-join:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #047857, 0 4rpx 8rpx rgba(16, 185, 129, 0.2);
}

.btn-join-text {
  font-size: 28rpx;
  font-weight: 700;
  color: white;
}

.online-tip {
  text-align: center;
  font-size: 26rpx;
