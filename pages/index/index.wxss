    0 0 0 #5A9686,
    0 4rpx 12rpx rgba(126, 184, 168, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.icon-puzzle-img {
  width: 48rpx;
