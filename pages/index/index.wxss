    0 8rpx 0 #5A9686,
    0 12rpx 24rpx rgba(126, 184, 168, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.mode-puzzle:active {
  transform: translateY(8rpx);
