}

/* 联机对战返回按钮 - 全屏模式 */
.online-back-btn {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
