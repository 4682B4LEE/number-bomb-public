}

/* ========== 等待房间样式 ========== */
.online-waiting {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  padding-top: 100rpx;
  gap: 32rpx;
  position: relative;
}

.online-waiting .back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  z-index: 10;
}

.room-number-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  border-radius: 24rpx;
  border: 4rpx solid #3B82F6;
}

.room-number-label {
  font-size: 28rpx;
  color: #3B82F6;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.room-number-display {
  font-size: 64rpx;
  font-weight: 800;
  color: #1D4ED8;
  letter-spacing: 12rpx;
}

.digit-select-section,
.rule-select-section {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #E5E7EB;
}

.digit-options,
.rule-options {
  display: flex;
  gap: 16rpx;
}

.digit-btn,
.rule-btn {
  flex: 1;
  height: 72rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #6B7280;
  transition: all 0.2s ease;
}

.digit-btn.active,
.rule-btn.active {
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.players-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 32rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #E5E7EB;
}

.player-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  overflow: hidden;
}

.player-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.player-avatar.default {
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
}

.player-avatar.waiting {
  background: #F3F4F6;
}

.player-avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.waiting-dots {
  display: flex;
  gap: 8rpx;
}

.waiting-dot {
  width: 12rpx;
  height: 12rpx;
  background: #9CA3AF;
  border-radius: 50%;
  animation: waitingBounce 1.4s ease-in-out infinite;
}

.waiting-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.waiting-dot:nth-child(3) {
  animation-delay: 0.4s;
}

.player-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.player-tag.host {
  background: #DBEAFE;
  color: #1D4ED8;
}

.player-tag.guest {
  background: #FEF3C7;
  color: #92400E;
}

.invite-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(180deg, #10B981 0%, #059669 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 0 #047857, 0 12rpx 24rpx rgba(16, 185, 129, 0.3);
  transition: all 0.2s ease;
  margin-top: 20rpx;
}

.invite-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #047857, 0 4rpx 12rpx rgba(16, 185, 129, 0.2);
}

.invite-icon {
  font-size: 36rpx;
}

.invite-text {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
}

@keyframes waitingBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 隐藏类 */
.hidden {
  display: none !important;
}

/* 玩法建议 */
.footer-suggestion {
  position: fixed;
  bottom: 20rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 100;
}

.suggestion-text {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 400;
}

/* ========== 疯狂周末跑马灯按钮 ========== */
.weekend-event-wrapper {
  position: absolute;
  bottom: 80rpx;
  left: 75rpx;
  right: 75rpx;
  z-index: 10;
}

.weekend-event-btn {
  position: relative;
  width: 100%;
  height: 96rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(230, 0, 18, 0.25);
}

/* 流光渐变边框效果 */
.gradient-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    90deg,
    #ff0000 0%,
    #ff8800 25%,
    #ffcc00 50%,
    #ff8800 75%,
    #ff0000 100%
  );
  background-size: 200% 100%;
  animation: gradientFlow 3s linear infinite;
  border-radius: 32rpx;
  z-index: 1;
}

@keyframes gradientFlow {
  0% { background-position: 0% 50%; }
  100% { background-position: 200% 50%; }
}

/* 按钮内容容器 */
.event-btn-content {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  right: 4rpx;
  bottom: 4rpx;
  background: white;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  z-index: 2;
  overflow: hidden;
}

/* 左侧固定内容 */
.event-left {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #fff5f5 0%, #ffffff 100%);
  height: 100%;
  flex-shrink: 0;
  border-right: 2rpx solid #ffe6e6;
}

.event-icon-svg {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.event-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #cc292b;
}

/* 右侧跑马灯区域 */
.event-marquee {
  flex: 1;
  height: 100%;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
}

.marquee-content {
  position: absolute;
  white-space: nowrap;
  animation: marquee 12s linear infinite;
  padding-left: 100%;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

.marquee-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

/* 点击效果 */
.weekend-event-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(230, 0, 18, 0.2);
}

/* 每日挑战入口样式 */
.daily-challenge-section {
  margin: 0 40rpx 30rpx;
}

.daily-challenge-btn {
  display: flex;
  align-items: center;
  padding: 30rpx 36rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
