/* 音符图标 */
.bgm-note {
  font-size: 28rpx;
  font-weight: 900;
  transition: all 0.3s ease;
  position: relative;
  z-index: 2;
}

.bgm-note.playing {
  color: #E60012;
  animation: noteBounce 0.6s ease infinite;
}

.bgm-note.muted {
  color: #8E8E8E;
  opacity: 0.5;
}

/* 音符跳动动画 */
@keyframes noteBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-4rpx) scale(1.1); }
}

/* 音波动画 */
.bgm-sound-wave {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.bgm-sound-wave.active {
  opacity: 1;
}

.wave {
  width: 4rpx;
  height: 16rpx;
  background: #E60012;
  border-radius: 2rpx;
  margin: 0 2rpx;
  animation: waveAnimation 0.5s ease infinite;
}

.wave-1 { animation-delay: 0s; }
.wave-2 { animation-delay: 0.1s; }
.wave-3 { animation-delay: 0.2s; }

@keyframes waveAnimation {
  0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
  50% { transform: scaleY(1.2); opacity: 1; }
}

