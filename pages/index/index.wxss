/* 首页样式 */

/* 导入联机对战新样式 */
@import "online-styles.wxss";

/* 导入联机猜颜色样式 */
@import "online-color-styles.wxss";

/* 更新公告栏 - 简约现代风格 */
.announcement-bar {
  position: fixed;
  top: 16rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 200;
}

.announcement-inner {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 32rpx;
  backdrop-filter: blur(10px);
}

.announcement-tag {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: white;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.announcement-content-wrapper {
  flex: 1;
  overflow: hidden;
}

.announcement-text {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 600;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.announcement-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
  position: relative;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.announcement-close:active {
  background: rgba(59, 130, 246, 0.1);
}

.close-line {
  position: absolute;
  width: 16rpx;
  height: 2rpx;
  background: #9CA3AF;
  border-radius: 2rpx;
}

.close-line-1 {
  transform: rotate(45deg);
}

.close-line-2 {
  transform: rotate(-45deg);
}

.announcement-close:active .close-line {
  background: #6B7280;
}

/* 点击效果 */
.announcement-content-wrapper:active {
  opacity: 0.7;
}

/* 用户登录区域 */
.user-login-section {
  position: absolute;
  top: 120rpx;
  left: 40rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(12rpx);
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: all 0.2s ease;
}

.user-login-section:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.user-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 32rpx;
}

.login-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 600;
}

.user-name {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 登录按钮 - 重置button样式 */
.login-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.login-btn::after {
  border: none;
}

/* 已登录区域 */
.logged-in-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 【合规改造】用户资料展示区域 */
.user-profile-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-nickname {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 昵称输入弹窗 */
.nickname-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  max-width: 560rpx;
  background: white;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 40rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1f2937;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.nickname-input:focus {
  border-color: #00c3e3;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.btn-confirm {
  background: linear-gradient(135deg, #4dd0e1 0%, #00c3e3 100%);
  color: white;
}

/* 震动开关 - 任天堂风格 */
.vibration-switch-container {
  position: absolute;
  top: 120rpx;
  right: 180rpx;
  z-index: 100;
  padding: 20rpx;
}

.vibration-switch {
  width: 120rpx;
  height: 64rpx;
  position: relative;
  cursor: pointer;
}

.vibration-switch-track {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  position: relative;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow:
    inset 0 4rpx 8rpx rgba(0, 0, 0, 0.2),
    0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

/* 开启状态 - 蓝色 */
.vibration-switch.on .vibration-switch-track {
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
}

/* 关闭状态 - 任天堂灰色 */
.vibration-switch.off .vibration-switch-track {
  background: linear-gradient(180deg, #B8B8B8 0%, #8E8E8E 100%);
}

.vibration-switch-thumb {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF 0%, #F0F0F0 100%);
  position: absolute;
  top: 4rpx;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow:
    0 4rpx 8rpx rgba(0, 0, 0, 0.3),
    0 1rpx 2rpx rgba(255, 255, 255, 0.8) inset;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 开启时滑块位置 */
.vibration-switch.on .vibration-switch-thumb {
  left: 60rpx;
  transform: rotate(360deg);
}

/* 关闭时滑块位置 */
.vibration-switch.off .vibration-switch-thumb {
  left: 4rpx;
  transform: rotate(0deg);
}

/* 点击效果 */
.vibration-switch-container:active .vibration-switch-thumb {
  transform: scale(0.95);
}

.vibration-switch-container:active .vibration-switch.on .vibration-switch-thumb {
  transform: scale(0.95) rotate(360deg);
}

/* ========== 游戏化设置按钮 - 药丸形 ========== */
.game-settings-pill {
  position: absolute;
  top: 120rpx;
  right: 40rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 4px 10px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  transition: all 0.2s ease;
}

.game-settings-pill-active {
  transform: scale(0.95);
  box-shadow: 0 2px 6px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.03);
}

.game-settings-pill-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-settings-pill-icon svg {
  width: 100%;
  height: 100%;
}

.game-settings-pill-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #334155;
}

/* 修改资料按钮 - 在设置按钮左边 */
.edit-profile-pill {
  right: 200rpx; /* 在设置按钮左边，留出更大间距避免重叠 */
  background: #ffffff;
  border: none;
  padding: 16rpx 28rpx;
  margin: 0;
  line-height: normal;

  /* 👇 核心修复：强制取消微信 button 的默认宽度限制 */
  width: auto !important;
  min-width: 0 !important;

  /* 👇 推荐补充：使用 flex 让图标和文字紧凑对齐 */
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 8rpx; /* 控制图标和文字的间距 */
}

.edit-profile-pill::after {
  border: none;
}

.edit-profile-pill:active {
  transform: scale(0.95);
  box-shadow: 0 2px 6px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.03);
}

/* 隐私提示文案 */
.privacy-notice {
  position: absolute;
  top: 200rpx;
  right: 40rpx;
  z-index: 99;
  max-width: 320rpx;
  text-align: right;
}

.privacy-notice-text {
  font-size: 20rpx;
  color: #999;
  line-height: 1.4;
}

/* ========== 游戏化设置弹窗 ========== */
.game-settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.4);
}

.game-modal-container {
  position: relative;
  width: 600rpx;
  background: #ffffff;
  border-radius: 64rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20px 40px rgba(0,0,0,0.15), inset 0 2px 0 rgba(255,255,255,0.8);
  z-index: 1001;
}

/* 弹窗标题 */
.game-modal-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: #1e293b;
  text-align: center;
  letter-spacing: 8rpx;
  margin-bottom: 48rpx;
}

/* 设置列表 */
.game-settings-list {
  margin-bottom: 40rpx;
}

/* 设置行 */
.game-settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.game-settings-row:last-child {
  border-bottom: none;
}

.game-settings-row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

/* 图标盒子 */
.game-settings-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bgm-icon-box {
  background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
}

.vibe-icon-box {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
}

.sound-icon-box {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.clear-icon-box {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
}

.game-settings-icon {
  font-size: 40rpx;
}

.game-settings-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.game-settings-row-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.game-settings-arrow {
  font-size: 40rpx;
  color: #9ca3af;
  font-weight: 300;
  margin-right: 8rpx;
}

/* ========== 自定义游戏风开关 (3D Toggle) ========== */
.game-toggle {
  width: 110rpx;
  height: 64rpx;
  border-radius: 999rpx;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

/* 关闭状态 */
.game-toggle-off {
  background: #e5e7eb;
  box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.2);
}

.game-toggle-off .game-toggle-knob {
  transform: translateX(0);
}

/* 开启状态 */
.game-toggle-on {
  background: #4ade80;
  box-shadow: inset 0 4rpx 8rpx rgba(0,0,0,0.2);
}

.game-toggle-on .game-toggle-knob {
  transform: translateX(46rpx);
}

/* 滑块 */
.game-toggle-knob {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 52rpx;
  height: 52rpx;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.1), 0 4rpx 8rpx rgba(0,0,0,0.2);
  transition: transform 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* ========== 3D关闭按钮 ========== */
.game-modal-close-btn {
  width: 100%;
  height: 100rpx;
  background: #ef4444;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 0 #b91c1c, 0 16rpx 30rpx rgba(239, 68, 68, 0.3);
  transition: all 0.1s ease;
}

.game-modal-close-btn-active {
  transform: translateY(12rpx);
  box-shadow: 0 0 0 #b91c1c, 0 4rpx 10rpx rgba(239, 68, 68, 0.3);
}

.game-modal-close-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 图标包装器 */
.vibration-icon-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 手机震动图标 */
.phone-icon {
  position: relative;
  width: 32rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-body {
  width: 24rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #4A5568 0%, #2D3748 100%);
  border-radius: 4rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.phone-icon.active .phone-body {
  background: linear-gradient(180deg, #3B82F6 0%, #2563EB 100%);
  animation: phoneShake 0.3s ease infinite;
}

.phone-icon.muted .phone-body {
  background: linear-gradient(180deg, #9CA3AF 0%, #6B7280 100%);
  opacity: 0.6;
}

.phone-screen {
  width: 18rpx;
  height: 30rpx;
  background: linear-gradient(180deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 2rpx;
}

/* 手机震动动画 */
@keyframes phoneShake {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(-1rpx) rotate(-2deg); }
  75% { transform: translateX(1rpx) rotate(2deg); }
}

/* 震动波纹 */
.vibration-ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 60rpx;
  height: 60rpx;
  pointer-events: none;
}

.ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #3B82F6;
  border-radius: 50%;
  opacity: 0;
}

.ripple-1 {
  animation: rippleEffect 1s ease-out infinite;
}

.ripple-2 {
  animation: rippleEffect 1s ease-out 0.5s infinite;
}

@keyframes rippleEffect {
  0% {
    transform: translate(-50%, -50%) scale(0.5);
    opacity: 0.8;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

/* 装饰性光点 - 任天堂风格 */
.vibration-switch-track::before {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 16rpx;
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  box-shadow:
    80rpx 0 0 rgba(255, 255, 255, 0.4),
    40rpx 32rpx 0 rgba(255, 255, 255, 0.3);
}

