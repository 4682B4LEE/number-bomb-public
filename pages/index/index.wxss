/* ========== 联机大厅样式 ========== */
.online-hall {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  padding-top: 100rpx;
  position: relative;
  height: 100%;
}

.online-hall .back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  z-index: 10;
}

.create-room-section {
  margin-top: 20rpx;
}

.btn-create {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 0 #1D4ED8, 0 12rpx 24rpx rgba(59, 130, 246, 0.3);
