  display: flex;
  align-items: center;
  justify-content: center;
}

.puzzle-grid {
  width: 48rpx;
  height: 48rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 4rpx;
}

.puzzle-cell {
  border-radius: 6rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.cell-1 {
  background: #FCD34D;
}

.cell-2 {
  background: #F87171;
}

.cell-3 {
  background: #60A5FA;
}

.cell-4 {
  background: #34D399;
}

.mode-puzzle .mode-icon {
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

/* 残局模式按钮 - 潘通14-6017 Grayed Jade 灰玉色 */
.mode-puzzle {
  background: linear-gradient(180deg, #9ECCBE 0%, #7EB8A8 100%);
