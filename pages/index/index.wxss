}

.room-input::placeholder {
  color: #9CA3AF;
}

.btn-join {
  width: 140rpx;
  height: 88rpx;
  background: linear-gradient(180deg, #10B981 0%, #059669 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #047857, 0 8rpx 16rpx rgba(16, 185, 129, 0.3);
