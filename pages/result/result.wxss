/* 回合结果页样式 - 参考 txt 文件设计 */

/* ========== 获胜页面背景 ========== */
.bg-winner-p1 {
  background-color: #FFF1F2;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(230, 0, 18, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(250, 204, 21, 0.08) 0%, transparent 50%);
}

.bg-winner-p2 {
  background-color: #F0F9FF;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(74, 222, 128, 0.08) 0%, transparent 50%);
}

/* 背景图案 - 铺满整个页面 */
.bg-pattern-dots {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.12;
  pointer-events: none;
  background-size: 40rpx 40rpx;
  z-index: 1;
}

.pattern-red {
  background-image: radial-gradient(circle, #E60012 25%, transparent 25%);
}

.pattern-blue {
  background-image: radial-gradient(circle, #3B82F6 25%, transparent 25%);
}

/* ========== 彩带动画 - 在最前面 ========== */
.confetti-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 100;
}

.confetti {
  position: absolute;
  top: -20rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 2rpx;
  animation: fall 4s linear infinite;
  opacity: 0;
}

.confetti-red {
  background: #E60012;
}

.confetti-gold {
  background: #FACC15;
  width: 8rpx;
  height: 8rpx;
}

.confetti-blue {
  background: #3B82F6;
}

.confetti-green {
  background: #4ADE80;
  width: 8rpx;
  height: 8rpx;
}

@keyframes fall {
  0% {
    transform: translateY(-10vh) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(110vh) rotate(720deg);
    opacity: 0;
  }
}

/* ========== 获胜页面容器 ========== */
.winner-page {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  position: relative;
  z-index: 10;
}

/* ========== 胜利徽章 - 悬浮在卡片上方 ========== */
.winner-badge {
  position: absolute;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 50;
}

.badge-p1 {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #E60012 100%);
  border-radius: 36rpx;
  border: 4rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(230, 0, 18, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(12deg) translateX(-50%);
}

.badge-p2 {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
  border-radius: 36rpx;
  border: 4rpx solid white;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(12deg) translateX(-50%);
}

/* 星星图标 */
.star-icon {
  width: 60rpx;
  height: 60rpx;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

.star-red {
  background: white;
}

/* 皇冠图标 */
.crown-icon {
  width: 60rpx;
  height: 50rpx;
  background: white;
  clip-path: polygon(50% 0%, 60% 40%, 100% 40%, 70% 70%, 80% 100%, 50% 80%, 20% 100%, 30% 70%, 0% 40%, 40% 40%);
}

.crown-blue {
  background: white;
}

/* 漂浮动画 - 上下浮动但不遮挡 */
.animate-float {
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateX(-50%) translateY(0) rotate(12deg); }
  50% { transform: translateX(-50%) translateY(-15rpx) rotate(15deg); }
}

/* ========== 获胜卡片 ========== */
.winner-card {
  width: 100%;
  max-width: 600rpx;
  background: white;
  border-radius: 48rpx;
  padding: 120rpx 48rpx 48rpx;
  position: relative;
  z-index: 20;
  margin-top: 60rpx;
}

.card-p1 {
  border: 4rpx solid #E60012;
  box-shadow: 8rpx 8rpx 0 rgba(230, 0, 18, 0.15);
}

.card-p2 {
  border: 4rpx solid #3B82F6;
  box-shadow: 8rpx 8rpx 0 rgba(59, 130, 246, 0.15);
}

/* 弹出动画 */
.animate-pop {
  animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  60% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* ========== 标题区 ========== */
.winner-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.winner-name {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.name-p1 {
  color: #E60012;
}

.name-p2 {
  color: #3B82F6;
}

.victory-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.tag-p1 {
  background: #F3F4F6;
}

.tag-p2 {
  background: #F3F4F6;
}

.victory-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #6B7280;
}

/* ========== 猜测数字区域 ========== */
.guess-section {
  margin-bottom: 48rpx;
}

.section-label {
  display: block;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #9CA3AF;
  margin-bottom: 24rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

.guess-digits {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.digit-block {
  width: 100rpx;
  height: 100rpx;
  background: white;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: digitPop 0.3s ease forwards;
  opacity: 0;
}

.block-p1 {
  border: 4rpx solid #E60012;
  border-bottom-width: 8rpx;
  border-right-width: 8rpx;
}

.block-p2 {
  border: 4rpx solid #3B82F6;
  border-bottom-width: 8rpx;
  border-right-width: 8rpx;
}

.digit-number {
  font-size: 48rpx;
  font-weight: 900;
  font-family: 'Varela Round', 'Nunito', sans-serif;
}

.block-p1 .digit-number {
  color: #E60012;
}

.block-p2 .digit-number {
  color: #3B82F6;
}

@keyframes digitPop {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* ========== 匹配数区域 ========== */
.match-section {
  position: relative;
  margin-bottom: 48rpx;
}

.match-bg {
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  transform: scale(1.05) translateY(8rpx);
  opacity: 0.2;
}

.bg-p1 {
  background: #E60012;
}

.bg-p2 {
  background: #3B82F6;
}

.match-content {
  position: relative;
  background: #F9FAFB;
  border: 2rpx dashed #E5E7EB;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.match-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #9CA3AF;
  margin-bottom: 8rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.match-score {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-current {
  font-size: 56rpx;
  font-weight: 900;
  font-family: 'Varela Round', 'Nunito', sans-serif;
}

.score-p1 {
  color: #E60012;
}

.score-p2 {
  color: #3B82F6;
}

.score-divider {
  font-size: 36rpx;
  font-weight: 700;
  color: #D1D5DB;
}

.score-total {
  font-size: 36rpx;
  font-weight: 700;
  color: #9CA3AF;
}

/* ========== 操作按钮 ========== */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.winner-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  transition: all 0.1s;
}

.winner-btn text {
  font-size: 32rpx;
  font-weight: 900;
  color: white;
}

.btn-p1 {
  background: linear-gradient(180deg, #FF6B6B 0%, #E60012 100%);
  box-shadow: 0 6rpx 0 #99000C;
}

.btn-p1:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #99000C;
}

.btn-p2 {
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
  box-shadow: 0 6rpx 0 #1D4ED8;
}

.btn-p2:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #1D4ED8;
}

/* 按钮箭头 */
.btn-arrow {
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid white;
  border-right: 4rpx solid white;
  transform: rotate(45deg);
}

.secondary-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.secondary-btn text {
  font-size: 28rpx;
  font-weight: 700;
  color: #6B7280;
}

.secondary-btn:active text {
  color: #374151;
}

/* ========== 普通结果页样式（保留原有设计）========== */
.normal-result {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

/* 标题区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-10deg);
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.logo-p1 {
  background: linear-gradient(180deg, #FF6B6B 0%, #E60012 100%);
}

.logo-p2 {
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
}

.logo-icon {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  color: white;
  font-size: 80rpx;
  font-weight: 900;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.title {
  font-size: 64rpx;
  font-weight: 900;
  color: #1F2937;
  letter-spacing: -2rpx;
  margin-bottom: 16rpx;
}

.subtitle-box {
  background: white;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  border: 2rpx solid #F3F4F6;
}

.subtitle {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 700;
}

/* 卡片 */
.card {
  width: 100%;
  max-width: 600rpx;
  padding: 48rpx;
  margin-bottom: 60rpx;
  background: white;
  border-radius: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08), 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #6B7280;
  font-weight: 700;
  margin-bottom: 40rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

/* 猜测数字展示 */
.guess-display {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.guess-digit-box {
  width: 96rpx;
  height: 112rpx;
  background: white;
  border: 4rpx solid #E5E7EB;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 0 #E5E7EB;
}

.guess-digit-text {
  font-size: 56rpx;
  font-weight: 900;
  color: #374151;
  font-family: 'Varela Round', 'Nunito', sans-serif;
}

/* 得分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-label {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: 700;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.score-display {
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: 24rpx;
}

.score-box.score-p1 {
  background: linear-gradient(180deg, #FFF1F2 0%, #FFE4E6 100%);
  border: 4rpx solid #E60012;
}

.score-box.score-p1 .score-num,
.score-box.score-p1 .score-divider,
.score-box.score-p1 .score-total {
  color: #E60012;
}

.score-box.score-p2 {
  background: linear-gradient(180deg, #F0F9FF 0%, #E0F2FE 100%);
  border: 4rpx solid #3B82F6;
}

.score-box.score-p2 .score-num,
.score-box.score-p2 .score-divider,
.score-box.score-p2 .score-total {
  color: #3B82F6;
}

.score-num {
  font-size: 64rpx;
  font-weight: 900;
  font-family: 'Varela Round', 'Nunito', sans-serif;
}

.score-divider {
  font-size: 48rpx;
  font-weight: 700;
  margin: 0 16rpx;
}

.score-total {
  font-size: 48rpx;
  font-weight: 700;
}

/* 提示信息 */
.hint-box {
  text-align: center;
  padding: 16rpx 32rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  border: 2rpx solid #F3F4F6;
}

.hint-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 开始按钮 */
.start-btn {
  width: 100%;
  max-width: 600rpx;
  height: 120rpx;
  color: white;
  font-size: 40rpx;
  font-weight: 900;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 rgba(0, 0, 0, 0.2);
}

.start-btn.btn-p1 {
  background: linear-gradient(180deg, #FF6B6B 0%, #E60012 100%);
  box-shadow: 0 8rpx 0 #99000C;
}

.start-btn.btn-p1:active {
  box-shadow: 0 0 0 #99000C;
}

.start-btn.btn-p2 {
  background: linear-gradient(180deg, #60A5FA 0%, #3B82F6 100%);
  box-shadow: 0 8rpx 0 #1D4ED8;
}

.start-btn.btn-p2:active {
  box-shadow: 0 0 0 #1D4ED8;
}
