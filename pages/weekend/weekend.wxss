/* 全局基础样式 */
page {
  background-color: #f5f6f8;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* 背景波点 */
.bg-pattern {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: radial-gradient(#d1d1d1 2rpx, transparent 2rpx);
  background-size: 30rpx 30rpx;
  z-index: -1;
}

/* 页面容器 */
.page-container {
  padding: 40rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* 工具类 */
.bold { font-weight: bold; }
.highlight { color: #cc292b; font-weight: bold; }

/* 顶部标题栏 */
.header {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  padding-top: 20rpx;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-right: 30rpx;
  font-weight: bold;
  color: #666;
  font-size: 32rpx;
}

.back-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.page-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #1c2536;
  letter-spacing: 2rpx;
}

/* 卡片样式 */
.section-card {
  background: white;
  border-radius: 48rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.03);
  animation: slideUp 0.5s ease backwards;
}

.section-card:nth-child(2) { animation-delay: 0.1s; }
.section-card:nth-child(3) { animation-delay: 0.2s; }
.section-card:nth-child(4) { animation-delay: 0.3s; }

@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.title-bar {
  width: 12rpx;
  height: 40rpx;
  background: #cc292b;
  border-radius: 99rpx;
  margin-right: 20rpx;
}

.section-title text {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1c29;
}

/* 卡片内容 */
.card-content {
  padding: 0 10rpx;
}

.content-item {
  display: flex;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #555;
}

.content-item:last-child {
  margin-bottom: 0;
}

.item-label {
  color: #666;
  font-weight: 600;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.item-value {
  flex: 1;
  color: #333;
}

.content-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #555;
}

.reward-text {
  margin-bottom: 30rpx;
}

/* 提示框 */
.tip-box {
  background: #fef9e7;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.tip-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1c29;
}

.tip-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 48rpx;
}

/* 微信号展示条 */
.wechat-id-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  border: 2rpx solid #e8e8e8;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-top: 20rpx;
}

.wechat-id {
  font-family: 'Courier New', monospace;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1c29;
  letter-spacing: 2rpx;
}

.copy-btn {
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.copy-btn:active {
  background: #e8e8e8;
  transform: scale(0.98);
}

/* 底部装饰 */
.footer-decoration {
  text-align: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.footer-text {
  font-size: 32rpx;
  color: #999;
  font-weight: 600;
}
