/* 猜颜色胜利页样式 - Victor Design System */

/* 页面容器 */
.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: #f0f2f5;
}

/* 背景纹理 (Noise Texture) */
.noise-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  opacity: 0.4;
  mix-blend-mode: overlay;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.5'/%3E%3C/svg%3E");
}

/* 模糊背景层 */
.blur-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: linear-gradient(to bottom right, #fef2f2, #eff6ff);
}

/* 核心卡片容器 - 外层 */
.outer-card {
  position: relative;
  z-index: 10;
  width: 90%;
  max-width: 640rpx;
  background: #f8f9fa;
  border-radius: 80rpx;
  padding: 16rpx;
  box-shadow: 0 40rpx 120rpx -60rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  animation: slide-up 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

/* 内层白色卡片 */
.inner-card {
  background: white;
  border-radius: 64rpx;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 顶部金色光效背景 */
.gold-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 384rpx;
  background: linear-gradient(to bottom, rgba(251, 191, 36, 0.1), rgba(251, 191, 36, 0.05), transparent);
  pointer-events: none;
}

/* 奖杯动画区 */
.trophy-area {
  position: relative;
  margin-bottom: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 背后光晕 */
.trophy-glow {
  position: absolute;
  inset: 0;
  background: #fbbf24;
  filter: blur(60rpx);
  opacity: 0.3;
  border-radius: 50%;
  transform: scale(1.5);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(1.5); }
  50% { opacity: 0.5; transform: scale(1.6); }
}

/* 奖杯图标 */
.trophy-icon {
  font-size: 144rpx;
  position: relative;
  z-index: 10;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.2));
  animation: trophy-bounce 1s ease infinite;
}

@keyframes trophy-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

/* 闪烁星星 */
.sparkle {
  position: absolute;
  font-size: 48rpx;
  color: #fbbf24;
  animation: sparkle 1.5s ease infinite;
}

.star-1 {
  top: -32rpx;
  right: -48rpx;
  animation-delay: 0s;
}

.star-2 {
  bottom: 0;
  left: -48rpx;
  font-size: 36rpx;
  animation-delay: 0.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 标题与获胜者区域 */
.winner-section {
  text-align: center;
  margin-bottom: 64rpx;
  position: relative;
  z-index: 10;
  width: 100%;
}

.victory-title {
  font-size: 72rpx;
  font-weight: 900;
  color: #1f2937;
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
  display: block;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 获胜者 Badge */
.winner-badge {
  margin: 0 auto;
  width: 80%;
  padding: 32rpx 0;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-p1 {
  background: linear-gradient(to bottom right, #ff6b6b, #dc2626);
}

.badge-p2 {
  background: linear-gradient(to bottom right, #4dd0e1, #0891b2);
}

.winner-label-small {
  font-size: 20rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.8);
  text-transform: uppercase;
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
}

.winner-name {
  font-size: 52rpx;
  font-weight: 900;
  color: white;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 正确答案展示区 */
.answer-section {
  width: 100%;
  background: #f9fafb;
  border-radius: 48rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 48rpx;
  border: 2rpx solid #f3f4f6;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.answer-label {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 700;
  text-align: center;
  text-transform: uppercase;
  letter-spacing: 8rpx;
  margin-bottom: 32rpx;
  display: block;
}

.answer-colors {
  display: flex;
  justify-content: center;
  gap: 32rpx;
}

.answer-color {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.15), inset 0 -4rpx 8rpx rgba(0, 0, 0, 0.2), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
  animation: pop-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  opacity: 0;
  transform: scale(0);
}

@keyframes pop-in {
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* 颜色定义 - Royal Design System */
.red {
  background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444, #991b1b);
}

.green {
  background: radial-gradient(circle at 30% 30%, #6ee7b7, #10b981, #047857);
}

.blue {
  background: radial-gradient(circle at 30% 30%, #93c5fd, #3b82f6, #1e40af);
}

.yellow {
  background: radial-gradient(circle at 30% 30%, #fcd34d, #f59e0b, #b45309);
}

.purple {
  background: radial-gradient(circle at 30% 30%, #f0abfc, #d946ef, #86198f);
}

.gray {
  background: radial-gradient(circle at 30% 30%, #cbd5e1, #64748b, #334155);
}

/* 数据统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  width: 100%;
  margin-bottom: 64rpx;
}

.stat-box {
  background: white;
  border: 2rpx solid #f3f4f6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.stat-box:active {
  background: #f9fafb;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 900;
  color: #f59e0b;
  margin-bottom: 8rpx;
}

.stat-mode {
  font-size: 28rpx;
  font-weight: 800;
  color: #f59e0b;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 700;
}

/* 按钮区域 */
.button-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 3D 实体按键风格 */
.btn-wrapper {
  position: relative;
  width: 100%;
}

.btn-shadow {
  position: absolute;
  inset: 0;
  border-radius: 28rpx;
  transform: translateY(12rpx);
  transition: transform 0.1s ease;
}

.btn-shadow-yellow {
  background: #d97706;
}

.btn-shadow-gray {
  background: #475569;
}

.btn-wrapper:active .btn-shadow {
  transform: translateY(0);
}

.btn-main {
  position: relative;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: white;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transform: translateY(0);
  transition: transform 0.1s ease;
}

.btn-wrapper:active .btn-main {
  transform: translateY(12rpx);
}

.btn-yellow {
  background: linear-gradient(to bottom, #fbbf24, #f59e0b);
}

.btn-yellow:active {
  background: linear-gradient(to bottom, #f59e0b, #d97706);
}

.btn-gray {
  background: linear-gradient(to bottom, #64748b, #475569);
  font-weight: 700;
}

.btn-gray:active {
  background: linear-gradient(to bottom, #475569, #334155);
}

.btn-icon {
  margin-left: 16rpx;
  font-size: 36rpx;
}

/* 滑入动画 */
@keyframes slide-up {
  from {
    transform: translateY(80rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
